[Unit]
Description=IPTABLES Packet Filtering
ConditionPathExists=/usr/lib/nextos/iptables_helper
ConditionPathExists=|/storage/.cache/services/iptables.conf
Before=network.target
Wants=network.target

[Service]
Type=oneshot
EnvironmentFile=-/storage/.cache/services/iptables.conf
ExecStart=/usr/lib/nextos/iptables_helper enable
ExecReload=/usr/lib/nextos/iptables_helper enable
ExecStop=/usr/lib/nextos/iptables_helper disable
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
