# NextOS 2026-05-12: ${devpath} (aspas simples) era invalido para udev moderno;
# trocado por $env{DEVPATH} (forma canonica). Sem essa correcao a rule inteira
# era ignorada e USB wakeup ficava enabled.

ACTION!="add|change", GOTO="end"

DRIVER=="ehci-pci|xhci_hcd", RUN+="/bin/sh -c 'echo disabled > /sys$env{DEVPATH}/power/wakeup'"

LABEL="end"
