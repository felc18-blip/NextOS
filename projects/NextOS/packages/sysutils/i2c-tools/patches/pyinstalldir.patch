From: NextOS
Date: 2026-05-28
Subject: [PATCH] i2c-tools 4.4: py-smbus install respeitar DESTDIR

i2c-tools 4.4 Module.mk usa apenas $(DISTUTILS) install --prefix=$(PREFIX).
Sem $(DESTDIR), python setup.py install vai pro /usr do HOST (toolchain),
não pro rootfs do target. Adicionar --root=$(DESTDIR) preserva PREFIX.

--- a/py-smbus/Module.mk
+++ b/py-smbus/Module.mk
@@ -22,7 +22,7 @@ clean-python:
 	rm -rf py-smbus/build

 install-python:
-	$(DISTUTILS) install --prefix="$(PREFIX)"
+	$(DISTUTILS) install --root="$(DESTDIR)" --prefix="$(PREFIX)"

 all: all-python

