+struct DrmPresenter {
+    int fd = -1;
+    gbm_device *gbm = nullptr;
+    uint32_t crtc = 0;
+    uint32_t conn = 0;
+    drmModeModeInfo mode{};
+    bool first_flip = true;
+    struct Buf {
+        gbm_bo *bo = nullptr;
+        uint32_t fb = 0;
+        vk::DeviceMemory mem;
+    };
+    std::vector<Buf> bufs;
+};
+
+bool ScreenRenderer::init_drm_present() {
+    drm = new DrmPresenter();
+    // SDL's kmsdrm backend (and/or the Mali ICD) opens its own card0 fd inside THIS process and
+    // holds DRM master on it. The kernel allows only one master per device, so our fd gets EBUSY.
+    // Find every card0 fd in this process and drop master on it, freeing it for us.
+    if (DIR *d = opendir("/proc/self/fd")) {
+        struct dirent *e;
+        while ((e = readdir(d)) != nullptr) {
+            int fd = atoi(e->d_name);
+            if (fd <= 2) continue;
+            char path[64], target[256];
+            snprintf(path, sizeof(path), "/proc/self/fd/%s", e->d_name);
+            ssize_t n = readlink(path, target, sizeof(target) - 1);
+            if (n > 0) {
+                target[n] = 0;
+                if (strstr(target, "/dev/dri/card")) {
+                    int r = drmDropMaster(fd);
+                    if (r == 0)
+                        LOG_INFO("DRM present: dropped DRM master held on fd={} ({})", fd, target);
+                }
+            }
+        }
+        closedir(d);
+    }
+    drm->fd = open("/dev/dri/card0", O_RDWR | O_CLOEXEC);
+    if (drm->fd < 0) {
+        LOG_ERROR("DRM present: could not open /dev/dri/card0");
+        return false;
+    }
+    int sm = drmSetMaster(drm->fd);
+    for (int i = 0; sm != 0 && i < 50; i++) { usleep(20000); sm = drmSetMaster(drm->fd); }
+    if (sm != 0)
+        LOG_WARN("DRM present: could not acquire DRM master (errno {})", errno);
+    drm->gbm = gbm_create_device(drm->fd);
+    if (!drm->gbm) {
+        LOG_ERROR("DRM present: gbm_create_device failed");
+        return false;
+    }
+    drmModeRes *res = drmModeGetResources(drm->fd);
+    if (!res) {
+        LOG_ERROR("DRM present: drmModeGetResources failed");
+        return false;
+    }
+    drmModeConnector *conn = nullptr;
+    for (int i = 0; i < res->count_connectors; i++) {
+        drmModeConnector *c = drmModeGetConnector(drm->fd, res->connectors[i]);
+        if (c && c->connection == DRM_MODE_CONNECTED && c->count_modes > 0) {
+            conn = c;
+            break;
+        }
+        if (c)
+            drmModeFreeConnector(c);
+    }
+    if (!conn) {
+        LOG_ERROR("DRM present: no connected connector");
+        drmModeFreeResources(res);
+        return false;
+    }
+    drm->conn = conn->connector_id;
+    drm->mode = conn->modes[0];
+    for (int i = 0; i < conn->count_modes; i++) {
+        if (conn->modes[i].type & DRM_MODE_TYPE_PREFERRED) {
+            drm->mode = conn->modes[i];
+            break;
+        }
+    }
+    drmModeEncoder *enc = drmModeGetEncoder(drm->fd, conn->encoder_id);
+    if (enc) {
+        drm->crtc = enc->crtc_id;
+        drmModeFreeEncoder(enc);
+    }
+    if (!drm->crtc && res->count_crtcs > 0)
+        drm->crtc = res->crtcs[0];
+    drmModeFreeConnector(conn);
+    drmModeFreeResources(res);
+    extent = vk::Extent2D{ drm->mode.hdisplay, drm->mode.vdisplay };
+    LOG_INFO("DRM present: conn {} crtc {} {}x{}@{}", drm->conn, drm->crtc,
+        drm->mode.hdisplay, drm->mode.vdisplay, drm->mode.vrefresh);
+    return true;
+}
+
+void ScreenRenderer::drm_create_images() {
+    const uint32_t W = drm->mode.hdisplay;
+    const uint32_t H = drm->mode.vdisplay;
+    swapchain_size = 3;
+    swapchain_images.resize(swapchain_size);
+    drm->bufs.resize(swapchain_size);
+    uint64_t linear = DRM_FORMAT_MOD_LINEAR;
+    vk::PhysicalDeviceMemoryProperties mem_props = state.physical_device.getMemoryProperties();
+    for (uint32_t i = 0; i < swapchain_size; i++) {
+        DrmPresenter::Buf &b = drm->bufs[i];
+        b.bo = gbm_bo_create_with_modifiers(drm->gbm, W, H, GBM_FORMAT_XRGB8888, &linear, 1);
+        if (!b.bo) {
+            LOG_ERROR("DRM present: gbm_bo_create_with_modifiers failed for buffer {}", i);
+            return;
+        }
+        int dmafd = gbm_bo_get_fd(b.bo);
+        uint32_t stride = gbm_bo_get_stride(b.bo);
+        uint32_t handle = gbm_bo_get_handle(b.bo).u32;
+        uint32_t handles[4] = { handle, 0, 0, 0 };
+        uint32_t strides[4] = { stride, 0, 0, 0 };
+        uint32_t offsets[4] = { 0, 0, 0, 0 };
+        if (drmModeAddFB2(drm->fd, W, H, DRM_FORMAT_XRGB8888, handles, strides, offsets, &b.fb, 0))
+            LOG_ERROR("DRM present: drmModeAddFB2 failed for buffer {}", i);
+
+        vk::SubresourceLayout plane_layout{};
+        plane_layout.offset = 0;
+        plane_layout.rowPitch = stride;
+        vk::ImageDrmFormatModifierExplicitCreateInfoEXT mod_info{
+            .drmFormatModifier = 0,
+            .drmFormatModifierPlaneCount = 1,
+            .pPlaneLayouts = &plane_layout,
+        };
+        vk::ExternalMemoryImageCreateInfo ext_info{
+            .pNext = &mod_info,
+            .handleTypes = vk::ExternalMemoryHandleTypeFlagBits::eDmaBufEXT,
+        };
+        vk::ImageCreateInfo image_info{
+            .pNext = &ext_info,
+            .imageType = vk::ImageType::e2D,
+            .format = surface_format.format,
+            .extent = vk::Extent3D{ W, H, 1 },
+            .mipLevels = 1,
+            .arrayLayers = 1,
+            .samples = vk::SampleCountFlagBits::e1,
+            .tiling = vk::ImageTiling::eDrmFormatModifierEXT,
+            .usage = vk::ImageUsageFlagBits::eColorAttachment | vk::ImageUsageFlagBits::eTransferDst,
+            .sharingMode = vk::SharingMode::eExclusive,
+            .initialLayout = vk::ImageLayout::eUndefined,
+        };
+        vk::Image image = state.device.createImage(image_info);
+        vk::MemoryRequirements mr = state.device.getImageMemoryRequirements(image);
+        uint32_t mem_type = 0;
+        for (uint32_t k = 0; k < mem_props.memoryTypeCount; k++) {
+            if (mr.memoryTypeBits & (1u << k)) {
+                mem_type = k;
+                break;
+            }
+        }
+        vk::ImportMemoryFdInfoKHR import_info{
+            .handleType = vk::ExternalMemoryHandleTypeFlagBits::eDmaBufEXT,
+            .fd = dmafd,
+        };
+        vk::MemoryDedicatedAllocateInfo ded_info{
+            .pNext = &import_info,
+            .image = image,
+        };
+        vk::MemoryAllocateInfo alloc_info{
+            .pNext = &ded_info,
+            .allocationSize = mr.size,
+            .memoryTypeIndex = mem_type,
+        };
+        b.mem = state.device.allocateMemory(alloc_info);
+        state.device.bindImageMemory(image, b.mem, 0);
+        swapchain_images[i] = image;
+    }
+    LOG_INFO("DRM present: {} scanout buffers imported into Vulkan", swapchain_size);
+}
+
+static void drm_flip_handler(int /*fd*/, unsigned /*frame*/, unsigned /*sec*/, unsigned /*usec*/, void *data) {
+    *static_cast<int *>(data) = 0;
+}
+
+void ScreenRenderer::drm_present(uint32_t image_idx) {
+    DrmPresenter::Buf &b = drm->bufs[image_idx];
+    if (drm->first_flip) {
+        drmModeSetCrtc(drm->fd, drm->crtc, b.fb, 0, 0, &drm->conn, 1, &drm->mode);
+        drm->first_flip = false;
+        return;
+    }
+    int pending = 1;
+    if (drmModePageFlip(drm->fd, drm->crtc, b.fb, DRM_MODE_PAGE_FLIP_EVENT, &pending) != 0) {
+        drmModeSetCrtc(drm->fd, drm->crtc, b.fb, 0, 0, &drm->conn, 1, &drm->mode);
+        return;
+    }
+    drmEventContext ev{};
+    ev.version = 2;
+    ev.page_flip_handler = drm_flip_handler;
+    struct pollfd pfd{};
+    pfd.fd = drm->fd;
+    pfd.events = POLLIN;
+    while (pending) {
+        if (poll(&pfd, 1, 100) > 0)
+            drmHandleEvent(drm->fd, &ev);
+        else
+            break;
+    }
+}
