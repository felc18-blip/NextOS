+VkResult VulkanDrmPresent::Acquire(VkDevice device, VkQueue queue, VkSemaphore acquireSemaphore, uint32_t *index) {
+	*index = nextIndex_ % ImageCount();
+	nextIndex_++;
+	return VK_SUCCESS;
+}
+
+VkResult VulkanDrmPresent::Present(VkDevice device, VkQueue queue, VkSemaphore renderingCompleteSemaphore, uint32_t index) {
+	// Copy the freshly rendered (optimal) image into the LINEAR scanout dma_buf. A transfer write
+	// actually lands in the dma_buf memory (a direct render into it does not, on this blob).
+	VkSubmitInfo si{ VK_STRUCTURE_TYPE_SUBMIT_INFO };
+	si.commandBufferCount = 1;
+	si.pCommandBuffers = &copyCmds_[index];
