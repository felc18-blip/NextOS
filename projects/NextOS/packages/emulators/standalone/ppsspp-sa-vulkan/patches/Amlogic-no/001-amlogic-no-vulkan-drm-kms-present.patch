+
+	DrmPresentImpl::Buf &b = impl_->bufs[index];
+	if (impl_->firstFlip) {
+		int rc = drmModeSetCrtc(impl_->fd, impl_->crtc, b.fb, 0, 0, &impl_->conn, 1, &impl_->mode);
+		INFO_LOG(Log::G3D, "NextOS DRM present: first setCrtc fb=%u crtc=%u conn=%u ret=%d", b.fb, impl_->crtc, impl_->conn, rc);
+		impl_->firstFlip = false;
+		return VK_SUCCESS;
+	}
+	int pending = 1;
+	if (drmModePageFlip(impl_->fd, impl_->crtc, b.fb, DRM_MODE_PAGE_FLIP_EVENT, &pending) != 0) {
+		drmModeSetCrtc(impl_->fd, impl_->crtc, b.fb, 0, 0, &impl_->conn, 1, &impl_->mode);
+		return VK_SUCCESS;
+	}
+	drmEventContext ev{};
+	ev.version = 2;
+	ev.page_flip_handler = drm_flip_handler;
+	struct pollfd pfd{};
+	pfd.fd = impl_->fd;
+	pfd.events = POLLIN;
+	while (pending) {
+		if (poll(&pfd, 1, 100) > 0) drmHandleEvent(impl_->fd, &ev);
+		else break;
+	}
+	return VK_SUCCESS;
+}
+
+void VulkanDrmPresent::Destroy(VkDevice device) {
+	if (copyFence_) { vkDestroyFence(device, copyFence_, nullptr); copyFence_ = VK_NULL_HANDLE; }
+	if (cmdPool_) { vkDestroyCommandPool(device, cmdPool_, nullptr); cmdPool_ = VK_NULL_HANDLE; }
+	for (auto img : renderImages_) if (img) vkDestroyImage(device, img, nullptr);
+	for (auto m : renderMem_) if (m) vkFreeMemory(device, m, nullptr);
+	for (auto img : scanoutImages_) if (img) vkDestroyImage(device, img, nullptr);
+	for (auto m : scanoutMem_) if (m) vkFreeMemory(device, m, nullptr);
+	renderImages_.clear(); renderMem_.clear(); scanoutImages_.clear(); scanoutMem_.clear();
+	if (impl_) {
+		for (auto &b : impl_->bufs) { if (b.fb) drmModeRmFB(impl_->fd, b.fb); if (b.bo) gbm_bo_destroy(b.bo); }
+		if (impl_->gbm) gbm_device_destroy(impl_->gbm);
+		if (impl_->fd >= 0) { drmDropMaster(impl_->fd); close(impl_->fd); }
+		delete impl_; impl_ = nullptr;
+	}
+	valid_ = false;
+}
