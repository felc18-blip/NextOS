+++ b/Common/GPU/Vulkan/VulkanDrmPresent.cpp
@@ -0,0 +1,315 @@
+// NextOS Amlogic-no: direct DRM/KMS present for Vulkan (Mali blob WSI is a stub). See header.
+#include "Common/GPU/Vulkan/VulkanDrmPresent.h"
+#include "Common/Log.h"
+
+#include <cstdio>
+#include <cstdlib>
+#include <cstring>
+#include <cerrno>
+
+#include <fcntl.h>
+#include <poll.h>
+#include <unistd.h>
+#include <dirent.h>
+
+#include <xf86drm.h>
+#include <xf86drmMode.h>
+#include <gbm.h>
+#include <drm/drm_fourcc.h>
+
+// PPSSPP routes all Vulkan entry points through its own loader in this namespace.
+using namespace PPSSPP_VK;
+
+struct DrmPresentImpl {
+	int fd = -1;
+	gbm_device *gbm = nullptr;
+	uint32_t crtc = 0;
+	uint32_t conn = 0;
+	drmModeModeInfo mode{};
+	bool firstFlip = true;
+	struct Buf {
+		gbm_bo *bo = nullptr;
+		uint32_t fb = 0;
+	};
+	std::vector<Buf> bufs;
+};
+
+static void drm_flip_handler(int, unsigned, unsigned, unsigned, void *data) {
+	*static_cast<int *>(data) = 0;
+}
+
+uint32_t VulkanDrmPresent::FindMemoryType(uint32_t typeBits, VkMemoryPropertyFlags props) const {
+	VkPhysicalDeviceMemoryProperties mp{};
+	vkGetPhysicalDeviceMemoryProperties(physicalDevice_, &mp);
+	for (uint32_t i = 0; i < mp.memoryTypeCount; i++) {
+		if ((typeBits & (1u << i)) && (mp.memoryTypes[i].propertyFlags & props) == props)
+			return i;
+	}
+	// Fall back to first allowed type.
+	for (uint32_t i = 0; i < mp.memoryTypeCount; i++)
+		if (typeBits & (1u << i))
+			return i;
+	return 0;
+}
+
+bool VulkanDrmPresent::Init(VkPhysicalDevice physicalDevice, VkDevice device, uint32_t graphicsQueueFamily, VkFormat format, int imageCount) {
+	impl_ = new DrmPresentImpl();
+	physicalDevice_ = physicalDevice;
+	device_ = device;
+	graphicsQueueFamily_ = graphicsQueueFamily;
+	format_ = format;
+
+	// SDL's kmsdrm backend (and/or the Mali ICD) holds DRM master on its own card fd. The kernel
+	// allows only one master, so drmSetMaster would get EBUSY. Drop master on every card fd first.
+	if (DIR *d = opendir("/proc/self/fd")) {
+		struct dirent *e;
+		while ((e = readdir(d)) != nullptr) {
+			int fd = atoi(e->d_name);
+			if (fd <= 2) continue;
+			char path[64], target[256];
+			snprintf(path, sizeof(path), "/proc/self/fd/%s", e->d_name);
+			ssize_t n = readlink(path, target, sizeof(target) - 1);
+			if (n > 0) { target[n] = 0; if (strstr(target, "/dev/dri/card")) drmDropMaster(fd); }
+		}
+		closedir(d);
+	}
+
+	impl_->fd = open("/dev/dri/card0", O_RDWR | O_CLOEXEC);
+	if (impl_->fd < 0) { ERROR_LOG(Log::G3D, "DRM present: open card0 failed"); return false; }
+	int sm = drmSetMaster(impl_->fd);
+	for (int i = 0; sm != 0 && i < 50; i++) { usleep(20000); sm = drmSetMaster(impl_->fd); }
+
+	impl_->gbm = gbm_create_device(impl_->fd);
+	if (!impl_->gbm) { ERROR_LOG(Log::G3D, "DRM present: gbm_create_device failed"); return false; }
+
+	drmModeRes *res = drmModeGetResources(impl_->fd);
+	if (!res) { ERROR_LOG(Log::G3D, "DRM present: drmModeGetResources failed"); return false; }
+	drmModeConnector *conn = nullptr;
+	for (int i = 0; i < res->count_connectors; i++) {
+		drmModeConnector *c = drmModeGetConnector(impl_->fd, res->connectors[i]);
+		if (c && c->connection == DRM_MODE_CONNECTED && c->count_modes > 0) { conn = c; break; }
+		if (c) drmModeFreeConnector(c);
+	}
+	if (!conn) { ERROR_LOG(Log::G3D, "DRM present: no connected connector"); drmModeFreeResources(res); return false; }
+	impl_->conn = conn->connector_id;
+	impl_->mode = conn->modes[0];
+	for (int i = 0; i < conn->count_modes; i++)
+		if (conn->modes[i].type & DRM_MODE_TYPE_PREFERRED) { impl_->mode = conn->modes[i]; break; }
+	drmModeEncoder *enc = drmModeGetEncoder(impl_->fd, conn->encoder_id);
+	if (enc) { impl_->crtc = enc->crtc_id; drmModeFreeEncoder(enc); }
+	if (!impl_->crtc && res->count_crtcs > 0) impl_->crtc = res->crtcs[0];
+	drmModeFreeConnector(conn);
+	drmModeFreeResources(res);
+
+	width_ = impl_->mode.hdisplay;
+	height_ = impl_->mode.vdisplay;
+	INFO_LOG(Log::G3D, "DRM present: conn %u crtc %u %ux%u@%u", impl_->conn, impl_->crtc, width_, height_, impl_->mode.vrefresh);
+
+	int count = imageCount < 2 ? 2 : imageCount;
+	renderImages_.resize(count);
+	renderMem_.resize(count);
+	scanoutImages_.resize(count);
+	scanoutMem_.resize(count);
+	impl_->bufs.resize(count);
+	uint64_t linear = DRM_FORMAT_MOD_LINEAR;
+
+	for (int i = 0; i < count; i++) {
+		// ---- render image: normal optimal-tiled, DEVICE_LOCAL. PPSSPP renders here. ----
+		VkImageCreateInfo rci{ VK_STRUCTURE_TYPE_IMAGE_CREATE_INFO };
+		rci.imageType = VK_IMAGE_TYPE_2D;
+		rci.format = format;
+		rci.extent = { width_, height_, 1 };
+		rci.mipLevels = 1;
+		rci.arrayLayers = 1;
+		rci.samples = VK_SAMPLE_COUNT_1_BIT;
+		rci.tiling = VK_IMAGE_TILING_OPTIMAL;
+		rci.usage = VK_IMAGE_USAGE_COLOR_ATTACHMENT_BIT | VK_IMAGE_USAGE_TRANSFER_SRC_BIT | VK_IMAGE_USAGE_TRANSFER_DST_BIT;
+		rci.sharingMode = VK_SHARING_MODE_EXCLUSIVE;
+		rci.initialLayout = VK_IMAGE_LAYOUT_UNDEFINED;
+		if (vkCreateImage(device, &rci, nullptr, &renderImages_[i]) != VK_SUCCESS) { ERROR_LOG(Log::G3D, "DRM present: render image %d failed", i); return false; }
+		VkMemoryRequirements rmr{};
+		vkGetImageMemoryRequirements(device, renderImages_[i], &rmr);
+		VkMemoryAllocateInfo rai{ VK_STRUCTURE_TYPE_MEMORY_ALLOCATE_INFO };
+		rai.allocationSize = rmr.size;
+		rai.memoryTypeIndex = FindMemoryType(rmr.memoryTypeBits, VK_MEMORY_PROPERTY_DEVICE_LOCAL_BIT);
+		if (vkAllocateMemory(device, &rai, nullptr, &renderMem_[i]) != VK_SUCCESS) { ERROR_LOG(Log::G3D, "DRM present: render mem %d failed", i); return false; }
+		vkBindImageMemory(device, renderImages_[i], renderMem_[i], 0);
+
+		// ---- scanout image: GBM LINEAR dma_buf imported into Vulkan, TRANSFER_DST only. ----
+		DrmPresentImpl::Buf &b = impl_->bufs[i];
+		b.bo = gbm_bo_create_with_modifiers(impl_->gbm, width_, height_, GBM_FORMAT_XRGB8888, &linear, 1);
+		if (!b.bo) { ERROR_LOG(Log::G3D, "DRM present: gbm_bo_create %d failed", i); return false; }
+		int dmafd = gbm_bo_get_fd(b.bo);
+		uint32_t stride = gbm_bo_get_stride(b.bo);
+		uint32_t handle = gbm_bo_get_handle(b.bo).u32;
+		uint32_t handles[4] = { handle, 0, 0, 0 }, strides[4] = { stride, 0, 0, 0 }, offsets[4] = { 0, 0, 0, 0 };
+		if (drmModeAddFB2(impl_->fd, width_, height_, DRM_FORMAT_XRGB8888, handles, strides, offsets, &b.fb, 0))
+			ERROR_LOG(Log::G3D, "DRM present: drmModeAddFB2 %d failed", i);
+
+		VkSubresourceLayout planeLayout{};
+		planeLayout.rowPitch = stride;
+		VkImageDrmFormatModifierExplicitCreateInfoEXT modInfo{ VK_STRUCTURE_TYPE_IMAGE_DRM_FORMAT_MODIFIER_EXPLICIT_CREATE_INFO_EXT };
+		modInfo.drmFormatModifier = DRM_FORMAT_MOD_LINEAR;
+		modInfo.drmFormatModifierPlaneCount = 1;
+		modInfo.pPlaneLayouts = &planeLayout;
+		VkExternalMemoryImageCreateInfo extInfo{ VK_STRUCTURE_TYPE_EXTERNAL_MEMORY_IMAGE_CREATE_INFO };
+		extInfo.pNext = &modInfo;
+		extInfo.handleTypes = VK_EXTERNAL_MEMORY_HANDLE_TYPE_DMA_BUF_BIT_EXT;
+		VkImageCreateInfo sci{ VK_STRUCTURE_TYPE_IMAGE_CREATE_INFO };
+		sci.pNext = &extInfo;
+		sci.imageType = VK_IMAGE_TYPE_2D;
+		sci.format = format;
+		sci.extent = { width_, height_, 1 };
+		sci.mipLevels = 1;
+		sci.arrayLayers = 1;
+		sci.samples = VK_SAMPLE_COUNT_1_BIT;
+		sci.tiling = VK_IMAGE_TILING_DRM_FORMAT_MODIFIER_EXT;
+		sci.usage = VK_IMAGE_USAGE_TRANSFER_DST_BIT;
+		sci.sharingMode = VK_SHARING_MODE_EXCLUSIVE;
+		sci.initialLayout = VK_IMAGE_LAYOUT_UNDEFINED;
+		if (vkCreateImage(device, &sci, nullptr, &scanoutImages_[i]) != VK_SUCCESS) { ERROR_LOG(Log::G3D, "DRM present: scanout image %d failed", i); return false; }
+		VkMemoryRequirements smr{};
+		vkGetImageMemoryRequirements(device, scanoutImages_[i], &smr);
+		VkImportMemoryFdInfoKHR imp{ VK_STRUCTURE_TYPE_IMPORT_MEMORY_FD_INFO_KHR };
+		imp.handleType = VK_EXTERNAL_MEMORY_HANDLE_TYPE_DMA_BUF_BIT_EXT;
+		imp.fd = dmafd;
+		VkMemoryDedicatedAllocateInfo ded{ VK_STRUCTURE_TYPE_MEMORY_DEDICATED_ALLOCATE_INFO };
+		ded.pNext = &imp;
+		ded.image = scanoutImages_[i];
+		VkMemoryAllocateInfo sai{ VK_STRUCTURE_TYPE_MEMORY_ALLOCATE_INFO };
+		sai.pNext = &ded;
+		sai.allocationSize = smr.size;
+		sai.memoryTypeIndex = FindMemoryType(smr.memoryTypeBits, 0);
+		if (vkAllocateMemory(device, &sai, nullptr, &scanoutMem_[i]) != VK_SUCCESS) { ERROR_LOG(Log::G3D, "DRM present: scanout import %d failed", i); return false; }
+		vkBindImageMemory(device, scanoutImages_[i], scanoutMem_[i], 0);
+	}
+
+	// Command pool + per-index pre-recorded copy command buffers (render[i] -> scanout[i]).
+	VkCommandPoolCreateInfo pci{ VK_STRUCTURE_TYPE_COMMAND_POOL_CREATE_INFO };
+	pci.queueFamilyIndex = graphicsQueueFamily_;
+	pci.flags = VK_COMMAND_POOL_CREATE_RESET_COMMAND_BUFFER_BIT;
+	vkCreateCommandPool(device, &pci, nullptr, &cmdPool_);
+	copyCmds_.resize(count);
+	VkCommandBufferAllocateInfo cbai{ VK_STRUCTURE_TYPE_COMMAND_BUFFER_ALLOCATE_INFO };
+	cbai.commandPool = cmdPool_;
+	cbai.level = VK_COMMAND_BUFFER_LEVEL_PRIMARY;
+	cbai.commandBufferCount = count;
+	vkAllocateCommandBuffers(device, &cbai, copyCmds_.data());
+
+	for (int i = 0; i < count; i++) {
+		VkCommandBufferBeginInfo bi{ VK_STRUCTURE_TYPE_COMMAND_BUFFER_BEGIN_INFO };
+		vkBeginCommandBuffer(copyCmds_[i], &bi);
+
+		VkImageMemoryBarrier toCopy[2]{};
+		// render[i]: written by PPSSPP (GENERAL) -> readable by transfer.
+		toCopy[0].sType = VK_STRUCTURE_TYPE_IMAGE_MEMORY_BARRIER;
+		toCopy[0].oldLayout = VK_IMAGE_LAYOUT_GENERAL;
+		toCopy[0].newLayout = VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL;
+		toCopy[0].srcAccessMask = VK_ACCESS_COLOR_ATTACHMENT_WRITE_BIT | VK_ACCESS_MEMORY_WRITE_BIT;
+		toCopy[0].dstAccessMask = VK_ACCESS_TRANSFER_READ_BIT;
+		toCopy[0].image = renderImages_[i];
+		toCopy[0].subresourceRange = { VK_IMAGE_ASPECT_COLOR_BIT, 0, 1, 0, 1 };
+		toCopy[0].srcQueueFamilyIndex = toCopy[0].dstQueueFamilyIndex = VK_QUEUE_FAMILY_IGNORED;
+		// scanout[i]: any -> transfer dst.
+		toCopy[1] = toCopy[0];
+		toCopy[1].oldLayout = VK_IMAGE_LAYOUT_UNDEFINED;
+		toCopy[1].newLayout = VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL;
+		toCopy[1].srcAccessMask = 0;
+		toCopy[1].dstAccessMask = VK_ACCESS_TRANSFER_WRITE_BIT;
+		toCopy[1].image = scanoutImages_[i];
+		vkCmdPipelineBarrier(copyCmds_[i], VK_PIPELINE_STAGE_ALL_COMMANDS_BIT, VK_PIPELINE_STAGE_TRANSFER_BIT, 0, 0, nullptr, 0, nullptr, 2, toCopy);
+
+		VkImageCopy region{};
+		region.srcSubresource = { VK_IMAGE_ASPECT_COLOR_BIT, 0, 0, 1 };
+		region.dstSubresource = { VK_IMAGE_ASPECT_COLOR_BIT, 0, 0, 1 };
+		region.extent = { width_, height_, 1 };
+		vkCmdCopyImage(copyCmds_[i], renderImages_[i], VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL, scanoutImages_[i], VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL, 1, &region);
+
+		// Make the transfer write visible to the display engine reading the dma_buf, and put
+		// render[i] back to GENERAL so PPSSPP's next frame can render into it again.
+		VkImageMemoryBarrier afterCopy[2]{};
+		afterCopy[0].sType = VK_STRUCTURE_TYPE_IMAGE_MEMORY_BARRIER;
+		afterCopy[0].oldLayout = VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL;
+		afterCopy[0].newLayout = VK_IMAGE_LAYOUT_GENERAL;
+		afterCopy[0].srcAccessMask = VK_ACCESS_TRANSFER_WRITE_BIT;
+		afterCopy[0].dstAccessMask = VK_ACCESS_MEMORY_READ_BIT;
+		afterCopy[0].image = scanoutImages_[i];
+		afterCopy[0].subresourceRange = { VK_IMAGE_ASPECT_COLOR_BIT, 0, 1, 0, 1 };
+		afterCopy[0].srcQueueFamilyIndex = afterCopy[0].dstQueueFamilyIndex = VK_QUEUE_FAMILY_IGNORED;
+		afterCopy[1] = afterCopy[0];
+		afterCopy[1].oldLayout = VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL;
+		afterCopy[1].newLayout = VK_IMAGE_LAYOUT_GENERAL;
+		afterCopy[1].srcAccessMask = VK_ACCESS_TRANSFER_READ_BIT;
+		afterCopy[1].dstAccessMask = VK_ACCESS_COLOR_ATTACHMENT_WRITE_BIT | VK_ACCESS_MEMORY_WRITE_BIT;
+		afterCopy[1].image = renderImages_[i];
