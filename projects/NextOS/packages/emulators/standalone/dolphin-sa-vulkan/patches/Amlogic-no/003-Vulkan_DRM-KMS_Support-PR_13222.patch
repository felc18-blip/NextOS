 #endif
+
+#if defined(VK_USE_PLATFORM_DISPLAY_KHR)
+  if (wstype == WindowSystemType::DRM)
+  {
+    if (!AddExtension(VK_KHR_DISPLAY_EXTENSION_NAME, true))
+    {
+      return false;
+    }
+    if (!AddExtension(VK_KHR_SURFACE_EXTENSION_NAME, true))
+    {
