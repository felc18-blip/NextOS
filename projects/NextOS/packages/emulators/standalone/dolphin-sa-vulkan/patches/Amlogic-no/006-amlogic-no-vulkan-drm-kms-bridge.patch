+// NextOS Amlogic-no: direct DRM/KMS present for Vulkan (Mali blob WSI is a stub). See header.
+#include "VideoBackends/Vulkan/VKDrmPresent.h"
+
+#include "Common/Logging/Log.h"
+
+#include <cstdio>
+#include <cstdlib>
+#include <cstring>
+
+#include <fcntl.h>
+#include <poll.h>
+#include <unistd.h>
+#include <dirent.h>
+
+#include <xf86drm.h>
+#include <xf86drmMode.h>
+#include <gbm.h>
+#include <drm/drm_fourcc.h>
+
+namespace Vulkan
+{
+struct DrmPresentImpl
+{
+  int fd = -1;
+  gbm_device* gbm = nullptr;
+  uint32_t crtc = 0;
+  uint32_t conn = 0;
+  drmModeModeInfo mode{};
+  bool first_flip = true;
+  struct Buf
+  {
+    gbm_bo* bo = nullptr;
+    uint32_t fb = 0;
+  };
+  std::vector<Buf> bufs;
+};
+
+static VKDrmPresent* s_instance = nullptr;
+
+static void drm_flip_handler(int, unsigned, unsigned, unsigned, void* data)
+{
+  *static_cast<int*>(data) = 0;
+}
+
+VKDrmPresent* VKDrmPresent::GetInstance()
+{
+  return s_instance;
+}
+
+bool VKDrmPresent::Create(VkPhysicalDevice physical_device, VkDevice device, uint32_t graphics_queue_family,
+                          VkQueue graphics_queue, VkFormat format, int image_count)
+{
+  s_instance = new VKDrmPresent();
+  if (!s_instance->Init(physical_device, device, graphics_queue_family, graphics_queue, format, image_count))
+  {
+    s_instance->Shutdown();
+    delete s_instance;
+    s_instance = nullptr;
+    return false;
+  }
+  return true;
+}
+
+void VKDrmPresent::Destroy()
+{
+  if (s_instance)
+  {
+    s_instance->Shutdown();
+    delete s_instance;
+    s_instance = nullptr;
+  }
+}
+
+uint32_t VKDrmPresent::FindMemoryType(uint32_t type_bits, VkMemoryPropertyFlags props) const
+{
+  VkPhysicalDeviceMemoryProperties mp{};
+  vkGetPhysicalDeviceMemoryProperties(m_physical_device, &mp);
+  for (uint32_t i = 0; i < mp.memoryTypeCount; i++)
+  {
+    if ((type_bits & (1u << i)) && (mp.memoryTypes[i].propertyFlags & props) == props)
+      return i;
+  }
+  for (uint32_t i = 0; i < mp.memoryTypeCount; i++)
+    if (type_bits & (1u << i))
+      return i;
+  return 0;
+}
+
+bool VKDrmPresent::Init(VkPhysicalDevice physical_device, VkDevice device, uint32_t graphics_queue_family,
+                        VkQueue graphics_queue, VkFormat format, int image_count)
+{
+  m_impl = new DrmPresentImpl();
+  m_physical_device = physical_device;
+  m_device = device;
+  m_graphics_queue = graphics_queue;
+  m_graphics_queue_family = graphics_queue_family;
+  m_format = format;
+
+  // Drop DRM master held by any other card fd (SDL/Mali ICD) so we can become master.
+  if (DIR* d = opendir("/proc/self/fd"))
+  {
+    struct dirent* e;
+    while ((e = readdir(d)) != nullptr)
+    {
+      int fd = atoi(e->d_name);
+      if (fd <= 2)
+        continue;
+      char path[300], target[256];
+      snprintf(path, sizeof(path), "/proc/self/fd/%s", e->d_name);
+      ssize_t n = readlink(path, target, sizeof(target) - 1);
+      if (n > 0)
+      {
+        target[n] = 0;
+        if (strstr(target, "/dev/dri/card"))
+          drmDropMaster(fd);
+      }
+    }
+    closedir(d);
+  }
+
+  m_impl->fd = open("/dev/dri/card0", O_RDWR | O_CLOEXEC);
+  if (m_impl->fd < 0)
+  {
+    ERROR_LOG_FMT(VIDEO, "DRM present: open card0 failed");
+    return false;
+  }
+  int sm = drmSetMaster(m_impl->fd);
+  for (int i = 0; sm != 0 && i < 50; i++)
+  {
+    usleep(20000);
+    sm = drmSetMaster(m_impl->fd);
+  }
+
+  m_impl->gbm = gbm_create_device(m_impl->fd);
+  if (!m_impl->gbm)
+  {
+    ERROR_LOG_FMT(VIDEO, "DRM present: gbm_create_device failed");
+    return false;
+  }
+
+  drmModeRes* res = drmModeGetResources(m_impl->fd);
+  if (!res)
+  {
+    ERROR_LOG_FMT(VIDEO, "DRM present: drmModeGetResources failed");
+    return false;
+  }
+  drmModeConnector* conn = nullptr;
+  for (int i = 0; i < res->count_connectors; i++)
+  {
+    drmModeConnector* c = drmModeGetConnector(m_impl->fd, res->connectors[i]);
+    if (c && c->connection == DRM_MODE_CONNECTED && c->count_modes > 0)
+    {
+      conn = c;
+      break;
+    }
+    if (c)
+      drmModeFreeConnector(c);
+  }
+  if (!conn)
+  {
+    ERROR_LOG_FMT(VIDEO, "DRM present: no connected connector");
+    drmModeFreeResources(res);
+    return false;
+  }
+  m_impl->conn = conn->connector_id;
+  m_impl->mode = conn->modes[0];
+  for (int i = 0; i < conn->count_modes; i++)
+    if (conn->modes[i].type & DRM_MODE_TYPE_PREFERRED)
+    {
+      m_impl->mode = conn->modes[i];
+      break;
+    }
+  drmModeEncoder* enc = drmModeGetEncoder(m_impl->fd, conn->encoder_id);
+  if (enc)
+  {
+    m_impl->crtc = enc->crtc_id;
+    drmModeFreeEncoder(enc);
+  }
+  if (!m_impl->crtc && res->count_crtcs > 0)
+    m_impl->crtc = res->crtcs[0];
+  drmModeFreeConnector(conn);
+  drmModeFreeResources(res);
+
+  m_width = m_impl->mode.hdisplay;
+  m_height = m_impl->mode.vdisplay;
+  INFO_LOG_FMT(VIDEO, "DRM present: conn {} crtc {} {}x{}@{}", m_impl->conn, m_impl->crtc, m_width,
+               m_height, m_impl->mode.vrefresh);
+
+  int count = image_count < 2 ? 2 : image_count;
+  m_render_images.resize(count);
+  m_render_mem.resize(count);
+  m_scanout_images.resize(count);
+  m_scanout_mem.resize(count);
+  m_impl->bufs.resize(count);
+  uint64_t linear = DRM_FORMAT_MOD_LINEAR;
+
+  for (int i = 0; i < count; i++)
+  {
+    // ---- render image: normal optimal-tiled, DEVICE_LOCAL. Dolphin renders here. ----
+    VkImageCreateInfo rci{VK_STRUCTURE_TYPE_IMAGE_CREATE_INFO};
+    rci.imageType = VK_IMAGE_TYPE_2D;
+    rci.format = format;
+    rci.extent = {m_width, m_height, 1};
+    rci.mipLevels = 1;
+    rci.arrayLayers = 1;
+    rci.samples = VK_SAMPLE_COUNT_1_BIT;
+    rci.tiling = VK_IMAGE_TILING_OPTIMAL;
+    rci.usage = VK_IMAGE_USAGE_COLOR_ATTACHMENT_BIT | VK_IMAGE_USAGE_TRANSFER_SRC_BIT |
+                VK_IMAGE_USAGE_TRANSFER_DST_BIT | VK_IMAGE_USAGE_SAMPLED_BIT;
+    rci.sharingMode = VK_SHARING_MODE_EXCLUSIVE;
+    rci.initialLayout = VK_IMAGE_LAYOUT_UNDEFINED;
+    if (vkCreateImage(device, &rci, nullptr, &m_render_images[i]) != VK_SUCCESS)
+    {
+      ERROR_LOG_FMT(VIDEO, "DRM present: render image {} failed", i);
+      return false;
+    }
+    VkMemoryRequirements rmr{};
+    vkGetImageMemoryRequirements(device, m_render_images[i], &rmr);
+    VkMemoryAllocateInfo rai{VK_STRUCTURE_TYPE_MEMORY_ALLOCATE_INFO};
+    rai.allocationSize = rmr.size;
+    rai.memoryTypeIndex = FindMemoryType(rmr.memoryTypeBits, VK_MEMORY_PROPERTY_DEVICE_LOCAL_BIT);
+    if (vkAllocateMemory(device, &rai, nullptr, &m_render_mem[i]) != VK_SUCCESS)
+    {
+      ERROR_LOG_FMT(VIDEO, "DRM present: render mem {} failed", i);
+      return false;
+    }
+    vkBindImageMemory(device, m_render_images[i], m_render_mem[i], 0);
+
+    // ---- scanout image: GBM LINEAR dma_buf imported into Vulkan, TRANSFER_DST only. ----
+    DrmPresentImpl::Buf& b = m_impl->bufs[i];
+    b.bo = gbm_bo_create_with_modifiers(m_impl->gbm, m_width, m_height, GBM_FORMAT_XRGB8888, &linear, 1);
+    if (!b.bo)
+    {
+      ERROR_LOG_FMT(VIDEO, "DRM present: gbm_bo_create {} failed", i);
+      return false;
+    }
+    int dmafd = gbm_bo_get_fd(b.bo);
+    uint32_t stride = gbm_bo_get_stride(b.bo);
+    uint32_t handle = gbm_bo_get_handle(b.bo).u32;
+    uint32_t handles[4] = {handle, 0, 0, 0}, strides[4] = {stride, 0, 0, 0}, offsets[4] = {0, 0, 0, 0};
+    if (drmModeAddFB2(m_impl->fd, m_width, m_height, DRM_FORMAT_XRGB8888, handles, strides, offsets, &b.fb, 0))
+      ERROR_LOG_FMT(VIDEO, "DRM present: drmModeAddFB2 {} failed", i);
+
+    VkSubresourceLayout plane_layout{};
+    plane_layout.rowPitch = stride;
+    VkImageDrmFormatModifierExplicitCreateInfoEXT mod_info{
+        VK_STRUCTURE_TYPE_IMAGE_DRM_FORMAT_MODIFIER_EXPLICIT_CREATE_INFO_EXT};
+    mod_info.drmFormatModifier = DRM_FORMAT_MOD_LINEAR;
+    mod_info.drmFormatModifierPlaneCount = 1;
+    mod_info.pPlaneLayouts = &plane_layout;
+    VkExternalMemoryImageCreateInfo ext_info{VK_STRUCTURE_TYPE_EXTERNAL_MEMORY_IMAGE_CREATE_INFO};
+    ext_info.pNext = &mod_info;
+    ext_info.handleTypes = VK_EXTERNAL_MEMORY_HANDLE_TYPE_DMA_BUF_BIT_EXT;
+    VkImageCreateInfo sci{VK_STRUCTURE_TYPE_IMAGE_CREATE_INFO};
+    sci.pNext = &ext_info;
+    sci.imageType = VK_IMAGE_TYPE_2D;
+    sci.format = format;
+    sci.extent = {m_width, m_height, 1};
+    sci.mipLevels = 1;
+    sci.arrayLayers = 1;
+    sci.samples = VK_SAMPLE_COUNT_1_BIT;
+    sci.tiling = VK_IMAGE_TILING_DRM_FORMAT_MODIFIER_EXT;
+    sci.usage = VK_IMAGE_USAGE_TRANSFER_DST_BIT;
+    sci.sharingMode = VK_SHARING_MODE_EXCLUSIVE;
+    sci.initialLayout = VK_IMAGE_LAYOUT_UNDEFINED;
+    if (vkCreateImage(device, &sci, nullptr, &m_scanout_images[i]) != VK_SUCCESS)
+    {
+      ERROR_LOG_FMT(VIDEO, "DRM present: scanout image {} failed", i);
+      return false;
+    }
+    VkMemoryRequirements smr{};
+    vkGetImageMemoryRequirements(device, m_scanout_images[i], &smr);
+    VkImportMemoryFdInfoKHR imp{VK_STRUCTURE_TYPE_IMPORT_MEMORY_FD_INFO_KHR};
+    imp.handleType = VK_EXTERNAL_MEMORY_HANDLE_TYPE_DMA_BUF_BIT_EXT;
+    imp.fd = dmafd;
+    VkMemoryDedicatedAllocateInfo ded{VK_STRUCTURE_TYPE_MEMORY_DEDICATED_ALLOCATE_INFO};
+    ded.pNext = &imp;
+    ded.image = m_scanout_images[i];
+    VkMemoryAllocateInfo sai{VK_STRUCTURE_TYPE_MEMORY_ALLOCATE_INFO};
+    sai.pNext = &ded;
+    sai.allocationSize = smr.size;
+    sai.memoryTypeIndex = FindMemoryType(smr.memoryTypeBits, 0);
+    if (vkAllocateMemory(device, &sai, nullptr, &m_scanout_mem[i]) != VK_SUCCESS)
+    {
+      ERROR_LOG_FMT(VIDEO, "DRM present: scanout import {} failed", i);
+      return false;
+    }
+    vkBindImageMemory(device, m_scanout_images[i], m_scanout_mem[i], 0);
+  }
+
+  // Command pool + per-index pre-recorded copy command buffers (render[i] -> scanout[i]).
+  VkCommandPoolCreateInfo pci{VK_STRUCTURE_TYPE_COMMAND_POOL_CREATE_INFO};
+  pci.queueFamilyIndex = m_graphics_queue_family;
+  pci.flags = VK_COMMAND_POOL_CREATE_RESET_COMMAND_BUFFER_BIT;
+  vkCreateCommandPool(device, &pci, nullptr, &m_cmd_pool);
+  m_copy_cmds.resize(count);
+  VkCommandBufferAllocateInfo cbai{VK_STRUCTURE_TYPE_COMMAND_BUFFER_ALLOCATE_INFO};
+  cbai.commandPool = m_cmd_pool;
+  cbai.level = VK_COMMAND_BUFFER_LEVEL_PRIMARY;
+  cbai.commandBufferCount = count;
+  vkAllocateCommandBuffers(device, &cbai, m_copy_cmds.data());
+
+  for (int i = 0; i < count; i++)
+  {
+    VkCommandBufferBeginInfo bi{VK_STRUCTURE_TYPE_COMMAND_BUFFER_BEGIN_INFO};
+    vkBeginCommandBuffer(m_copy_cmds[i], &bi);
+
+    VkImageMemoryBarrier to_copy[2]{};
+    to_copy[0].sType = VK_STRUCTURE_TYPE_IMAGE_MEMORY_BARRIER;
+    to_copy[0].oldLayout = VK_IMAGE_LAYOUT_GENERAL;
+    to_copy[0].newLayout = VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL;
+    to_copy[0].srcAccessMask = VK_ACCESS_COLOR_ATTACHMENT_WRITE_BIT | VK_ACCESS_MEMORY_WRITE_BIT;
+    to_copy[0].dstAccessMask = VK_ACCESS_TRANSFER_READ_BIT;
+    to_copy[0].image = m_render_images[i];
+    to_copy[0].subresourceRange = {VK_IMAGE_ASPECT_COLOR_BIT, 0, 1, 0, 1};
+    to_copy[0].srcQueueFamilyIndex = to_copy[0].dstQueueFamilyIndex = VK_QUEUE_FAMILY_IGNORED;
+    to_copy[1] = to_copy[0];
+    to_copy[1].oldLayout = VK_IMAGE_LAYOUT_UNDEFINED;
+    to_copy[1].newLayout = VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL;
+    to_copy[1].srcAccessMask = 0;
+    to_copy[1].dstAccessMask = VK_ACCESS_TRANSFER_WRITE_BIT;
+    to_copy[1].image = m_scanout_images[i];
+    vkCmdPipelineBarrier(m_copy_cmds[i], VK_PIPELINE_STAGE_ALL_COMMANDS_BIT,
+                         VK_PIPELINE_STAGE_TRANSFER_BIT, 0, 0, nullptr, 0, nullptr, 2, to_copy);
+
+    VkImageCopy region{};
+    region.srcSubresource = {VK_IMAGE_ASPECT_COLOR_BIT, 0, 0, 1};
+    region.dstSubresource = {VK_IMAGE_ASPECT_COLOR_BIT, 0, 0, 1};
+    region.extent = {m_width, m_height, 1};
+    vkCmdCopyImage(m_copy_cmds[i], m_render_images[i], VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL,
+                   m_scanout_images[i], VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL, 1, &region);
+
+    VkImageMemoryBarrier after[2]{};
+    after[0].sType = VK_STRUCTURE_TYPE_IMAGE_MEMORY_BARRIER;
+    after[0].oldLayout = VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL;
+    after[0].newLayout = VK_IMAGE_LAYOUT_GENERAL;
+    after[0].srcAccessMask = VK_ACCESS_TRANSFER_WRITE_BIT;
+    after[0].dstAccessMask = VK_ACCESS_MEMORY_READ_BIT;
+    after[0].image = m_scanout_images[i];
+    after[0].subresourceRange = {VK_IMAGE_ASPECT_COLOR_BIT, 0, 1, 0, 1};
+    after[0].srcQueueFamilyIndex = after[0].dstQueueFamilyIndex = VK_QUEUE_FAMILY_IGNORED;
+    after[1] = after[0];
+    after[1].oldLayout = VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL;
+    after[1].newLayout = VK_IMAGE_LAYOUT_GENERAL;
+    after[1].srcAccessMask = VK_ACCESS_TRANSFER_READ_BIT;
+    after[1].dstAccessMask = VK_ACCESS_COLOR_ATTACHMENT_WRITE_BIT | VK_ACCESS_MEMORY_WRITE_BIT;
+    after[1].image = m_render_images[i];
+    vkCmdPipelineBarrier(m_copy_cmds[i], VK_PIPELINE_STAGE_TRANSFER_BIT,
+                         VK_PIPELINE_STAGE_ALL_COMMANDS_BIT, 0, 0, nullptr, 0, nullptr, 2, after);
+
+    vkEndCommandBuffer(m_copy_cmds[i]);
+  }
+
+  VkFenceCreateInfo fi{VK_STRUCTURE_TYPE_FENCE_CREATE_INFO};
+  vkCreateFence(device, &fi, nullptr, &m_copy_fence);
+
+  INFO_LOG_FMT(VIDEO, "NextOS DRM present: {} render+linear scanout buffers ready (copy bridge)", count);
+  m_valid = true;
+  return true;
+}
+
+uint32_t VKDrmPresent::AcquireNextImage()
+{
+  uint32_t idx = m_next_index % GetImageCount();
+  m_next_index++;
+  return idx;
+}
+
+void VKDrmPresent::Present(uint32_t index)
+{
+  // Copy the freshly rendered (optimal) image into the LINEAR scanout dma_buf. A transfer write
+  // actually lands in the dma_buf memory (a direct render into it does not, on this blob).
+  VkSubmitInfo si{VK_STRUCTURE_TYPE_SUBMIT_INFO};
+  si.commandBufferCount = 1;
+  si.pCommandBuffers = &m_copy_cmds[index];
+  vkResetFences(m_device, 1, &m_copy_fence);
+  if (vkQueueSubmit(m_graphics_queue, 1, &si, m_copy_fence) != VK_SUCCESS)
+  {
+    ERROR_LOG_FMT(VIDEO, "NextOS DRM present: copy submit failed");
+    return;
+  }
+  vkWaitForFences(m_device, 1, &m_copy_fence, VK_TRUE, UINT64_MAX);
+
+  DrmPresentImpl::Buf& b = m_impl->bufs[index];
+  if (m_impl->first_flip)
+  {
+    drmModeSetCrtc(m_impl->fd, m_impl->crtc, b.fb, 0, 0, &m_impl->conn, 1, &m_impl->mode);
+    m_impl->first_flip = false;
+    return;
+  }
+  int pending = 1;
+  if (drmModePageFlip(m_impl->fd, m_impl->crtc, b.fb, DRM_MODE_PAGE_FLIP_EVENT, &pending) != 0)
+  {
+    drmModeSetCrtc(m_impl->fd, m_impl->crtc, b.fb, 0, 0, &m_impl->conn, 1, &m_impl->mode);
+    return;
+  }
+  drmEventContext ev{};
+  ev.version = 2;
+  ev.page_flip_handler = drm_flip_handler;
+  struct pollfd pfd{};
+  pfd.fd = m_impl->fd;
+  pfd.events = POLLIN;
+  while (pending)
+  {
+    if (poll(&pfd, 1, 100) > 0)
+      drmHandleEvent(m_impl->fd, &ev);
+    else
+      break;
+  }
+}
+
+void VKDrmPresent::Shutdown()
+{
+  if (m_copy_fence)
+    vkDestroyFence(m_device, m_copy_fence, nullptr);
+  if (m_cmd_pool)
+    vkDestroyCommandPool(m_device, m_cmd_pool, nullptr);
+  for (auto img : m_render_images)
+    if (img)
+      vkDestroyImage(m_device, img, nullptr);
+  for (auto m : m_render_mem)
+    if (m)
+      vkFreeMemory(m_device, m, nullptr);
+  for (auto img : m_scanout_images)
+    if (img)
+      vkDestroyImage(m_device, img, nullptr);
+  for (auto m : m_scanout_mem)
+    if (m)
+      vkFreeMemory(m_device, m, nullptr);
+  m_render_images.clear();
+  m_render_mem.clear();
+  m_scanout_images.clear();
+  m_scanout_mem.clear();
+  if (m_impl)
+  {
+    for (auto& b : m_impl->bufs)
+    {
+      if (b.fb)
+        drmModeRmFB(m_impl->fd, b.fb);
+      if (b.bo)
+        gbm_bo_destroy(b.bo);
+    }
+    if (m_impl->gbm)
+      gbm_device_destroy(m_impl->gbm);
+    if (m_impl->fd >= 0)
+    {
+      drmDropMaster(m_impl->fd);
+      close(m_impl->fd);
+    }
+    delete m_impl;
+    m_impl = nullptr;
+  }
+  m_valid = false;
+}
+}  // namespace Vulkan
--- /dev/null
+++ b/Source/Core/VideoBackends/Vulkan/VKDrmPresent.h
@@ -0,0 +1,67 @@
+// NextOS Amlogic-no (Mali Valhall G310 r44p0): direct DRM/KMS present for Vulkan.
+// The Mali blob's Vulkan WSI (VK_KHR_display swapchain) is a non-functional stub. We bypass
+// the swapchain: Dolphin renders into NORMAL optimal images (Mali free to use AFBC); each
+// present we vkCmdCopyImage them into GBM-allocated LINEAR dma_buf scanout buffers (a transfer
+// writes raw linear bytes that actually land in the dma_buf - a direct render does NOT on this
+// blob) and scan them out with a KMS pageflip. Same bridge proven on PPSSPP/Vita3K.
+#pragma once
+
+#include "VideoBackends/Vulkan/VulkanLoader.h"
+
+#include <cstdint>
+#include <vector>
+
+namespace Vulkan
+{
+struct DrmPresentImpl;
+
+class VKDrmPresent
+{
+public:
+  static VKDrmPresent* GetInstance();
+  static bool Create(VkPhysicalDevice physical_device, VkDevice device, uint32_t graphics_queue_family,
+                     VkQueue graphics_queue, VkFormat format, int image_count);
+  static void Destroy();
+
+  bool Valid() const { return m_valid; }
