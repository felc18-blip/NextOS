#
# Amlogic-no = S905X5 / X5M / S928X (SoC s7d, card AML-AUGESOUND). Áudio HDMI:
#
#   card0 device 0 = SPDIF-B  (rota interna -> HDMITX)   <- HDMI sai por aqui
#   card0 device 1 = TDM-C-T9015  (lineout analógico)
#   card0 device 2 = SPDIF  (óptico físico)
#
# Stream PCM -> SPDIF-B (hw:0,0) -> HDMITX. Pra o HDMITX pegar o áudio em PCM,
# 3 controles ALSA precisam estar certos — resolvidos por NOME (o numid varia
# por kernel/build; hardcodar numid foi o bug do script antigo):
#
#   'HDMITX Audio Source Select' = Spdif_b      (item 1) — senão escuta fonte errada
#   'Audio I2S to HDMITX Format' = Stereo PCM   (item 0) — default vem DTS (item 3) = mudo
#   'Audio I2S to HDMITX Mask'   = 3 (0b11, L+R)
#
# Verificado no X5M: depois de setados, os controles são ESTÁVEIS — não resetam
# em suspend/resume do sink nem em restart do wireplumber. Basta setar 1x no boot.
#
# NÃO usa os controles 'AIU * CTRL SRC' do S905W/GXL — não existem no AML-AUGE.

[ -e /proc/asound/card0 ] || exit 0

### Sink PipeWire explícito apontando pro SPDIF-B frontend (hw:0,0).
# (O auto-detect também cria um sink hdmi:0; o explícito tem prioridade e
# device conhecido, garantindo que o ES caia no SPDIF-B certo.)
PWCONF=/etc/pipewire/pipewire.conf.d/50-amlogic-hdmi.conf
PWCONF_NEW=$(mktemp)
mkdir -p "$(dirname "${PWCONF}")"

cat <<'EOF' >"${PWCONF_NEW}"
# Amlogic-no (S905X5/X5M/S928X, AML-AUGE) — sink HDMI explícito no SPDIF-B
# frontend (hw:0,0). Roteamento p/ HDMI via 'HDMITX Audio Source Select=Spdif_b'
# (ver quirk /usr/lib/autostart/quirks/platforms/Amlogic-no/085-audio).
context.objects = [
  {
    factory = adapter
    args = {
      factory.name = api.alsa.pcm.sink
      node.name = "alsa_output.hdmi-stereo"
      node.description = "HDMI Audio (Amlogic-no)"
      media.class = "Audio/Sink"
      api.alsa.path = "hw:0,0"
      audio.format = "S16LE"
      audio.rate = 48000
      audio.channels = 2
      audio.position = "FL,FR"
      priority.driver = 2000
      priority.session = 2000
    }
  }
]
EOF

if ! cmp -s "${PWCONF_NEW}" "${PWCONF}" 2>/dev/null; then
  mv "${PWCONF_NEW}" "${PWCONF}"
  # PipeWire é socket-activated; recarrega se já estiver de pé.
  systemctl is-active pipewire.service >/dev/null 2>&1 && \
    systemctl reload-or-restart pipewire pipewire-pulse wireplumber 2>/dev/null || true
else
  rm -f "${PWCONF_NEW}"
fi

### HDMITX routing — por NOME (numid varia). card0 = AML-AUGE.
amixer -c 0 -q cset name='HDMITX Audio Source Select' 1 2>/dev/null || true  # Spdif_b
amixer -c 0 -q cset name='Audio I2S to HDMITX Format' 0 2>/dev/null || true  # Stereo PCM
amixer -c 0 -q cset name='Audio I2S to HDMITX Mask'   3 2>/dev/null || true  # L+R
