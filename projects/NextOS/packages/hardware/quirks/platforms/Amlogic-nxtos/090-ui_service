### Set the default device configuration
# Sem este quirk, /usr/bin/autostart faz `systemctl start ${UI_SERVICE}` com
# var vazia (declarada em 999-export mas nunca atribuida) e a UI nao sobe.
# Amlogic-nxtos = TV box S905W Mali-450 + Lima + sway -> essway.service.
cat <<EOF >/storage/.config/profile.d/090-ui_service
UI_SERVICE="sway.service essway.service"
EOF
