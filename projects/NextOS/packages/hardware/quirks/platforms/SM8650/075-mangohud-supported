. /etc/profile

# Enable MangoHud support
MANGOHUD_ENABLED=$(get_setting "nextos.mangohud.enabled")
if [ ! -n "${MANGOHUD_ENABLED}" ]; then
  MANGOHUD_ENABLED="0"
  set_setting "nextos.mangohud.enabled" "${MANGOHUD_ENABLED}"
fi
